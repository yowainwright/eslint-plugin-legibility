{
  "name": "eslint-plugin-legibility",
  "version": "0.1.0",
  "description": "ESLint and Oxlint JS plugin rules for readable, performance-conscious code.",
  "license": "MIT",
  "type": "module",
  "author": "Jeffry Wainwright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yowainwright/eslint-plugin-legibility.git"
  },
  "bugs": {
    "url": "https://github.com/yowainwright/eslint-plugin-legibility/issues"
  },
  "homepage": "https://github.com/yowainwright/eslint-plugin-legibility#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "oxlint",
    "readability",
    "legibility",
    "performance",
    "ai"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE.md",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm build:plugin",
    "build:plugin": "tsc -p tsconfig.build.json",
    "build:runtime": "tsc -p tsconfig.json --noEmit false --declaration false --outDir .build --rootDir .",
    "typecheck": "pnpm build:plugin && tsc -p tsconfig.json",
    "lint": "pnpm build:plugin && eslint .",
    "lint:oxlint": "oxlint .",
    "pack:check": "pnpm build:plugin && pnpm pack --json --pack-destination ./.npm-cache",
    "prepack": "pnpm build:plugin",
    "release": "node scripts/release.ts",
    "release:patch": "node scripts/release.ts --increment=patch",
    "release:patch:dry": "node scripts/release.ts --increment=patch --dry-run",
    "release:minor": "node scripts/release.ts --increment=minor",
    "release:minor:dry": "node scripts/release.ts --increment=minor --dry-run",
    "release:major": "node scripts/release.ts --increment=major",
    "release:major:dry": "node scripts/release.ts --increment=major --dry-run",
    "release:beta": "node scripts/release.ts --preRelease=beta",
    "release:beta:dry": "node scripts/release.ts --preRelease=beta --dry-run",
    "release:alpha": "node scripts/release.ts --preRelease=alpha",
    "release:alpha:dry": "node scripts/release.ts --preRelease=alpha --dry-run",
    "release:tag": "node scripts/tag-release.ts",
    "release:tag:dry": "node scripts/tag-release.ts --dry-run",
    "release:tag:trusted": "node scripts/tag-release.ts --trusted-publishing",
    "release:dry": "node scripts/release.ts --dry-run",
    "test": "pnpm build:plugin && node --test tests/*.test.ts",
    "test:coverage": "pnpm build:plugin && mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info tests/*.test.ts && sed -e 's|^SF:dist/\\(.*\\)\\.js$|SF:src/\\1.ts|' coverage/lcov.info > coverage/src.info && mv coverage/src.info coverage/lcov.info",
    "test:compat": "pnpm build:plugin && pnpm build:runtime && node --test .build/tests/*.test.js",
    "validate": "pnpm typecheck && pnpm typecheck:strict && pnpm type-coverage && pnpm test && pnpm lint && pnpm lint:oxlint && pnpm pack:check",
    "validate:compat": "pnpm typecheck && pnpm typecheck:strict && pnpm type-coverage && pnpm test:compat && pnpm lint && pnpm lint:oxlint && pnpm pack:check",
    "typecheck:strict": "tsc -p tsconfig.build.json --noEmit --strict --noImplicitAny --noUncheckedIndexedAccess",
    "type-coverage": "type-coverage --strict --at-least 99.5 -- src/index.ts src/constants.ts src/types.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "jiti": "^2.7.0",
    "oxlint": "^1.0.0",
    "release-it": "20.1.0",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}",
      "commitArgs": [
        "--no-verify"
      ],
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    }
  }
}
