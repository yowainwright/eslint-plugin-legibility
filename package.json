{
  "name": "eslint-plugin-legibility",
  "version": "0.1.2",
  "description": "ESLint and Oxlint JS plugin rules for readable, performance-conscious code.",
  "license": "MIT",
  "type": "module",
  "author": "Jeffry Wainwright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yowainwright/eslint-plugin-legibility.git"
  },
  "bugs": {
    "url": "https://github.com/yowainwright/eslint-plugin-legibility/issues"
  },
  "homepage": "https://github.com/yowainwright/eslint-plugin-legibility#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "oxlint",
    "readability",
    "legibility",
    "performance",
    "ai"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm build:plugin",
    "build:plugin": "tsc -p tsconfig.build.json",
    "build:runtime": "tsc -p tsconfig.json --noEmit false --declaration false --outDir .build --rootDir .",
    "typecheck": "pnpm build:plugin && tsc -p tsconfig.json",
    "lint": "pnpm build:plugin && eslint .",
    "lint:oxlint": "oxlint .",
    "pack:check": "pnpm build:plugin && pnpm pack --json --pack-destination ./.npm-cache",
    "prepare": "sh scripts/prepare.sh",
    "prepack": "pnpm build:plugin",
    "install-hooks": "jiti scripts/install-hooks.ts",
    "release": "release-it",
    "release:current": "release-it --no-increment --ci",
    "release:current:dry": "release-it --no-increment --dry-run --ci",
    "release:patch": "release-it patch --ci",
    "release:patch:dry": "release-it patch --dry-run --ci",
    "release:minor": "release-it minor --ci",
    "release:minor:dry": "release-it minor --dry-run --ci",
    "release:major": "release-it major --ci",
    "release:major:dry": "release-it major --dry-run --ci",
    "release:beta": "release-it --preRelease=beta --ci",
    "release:beta:dry": "release-it --preRelease=beta --dry-run --ci",
    "release:alpha": "release-it --preRelease=alpha --ci",
    "release:alpha:dry": "release-it --preRelease=alpha --dry-run --ci",
    "release:dry": "release-it --dry-run --ci",
    "test": "pnpm build:plugin && node --test tests/*.test.ts",
    "test:bun": "pnpm build:plugin && bun test tests/*.test.ts",
    "test:coverage": "pnpm build:plugin && mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info tests/*.test.ts && sed -e 's|^SF:dist/\\(.*\\)\\.js$|SF:src/\\1.ts|' coverage/lcov.info > coverage/src.info && mv coverage/src.info coverage/lcov.info",
    "test:compat": "pnpm build:plugin && pnpm build:runtime && node --test .build/tests/*.test.js",
    "validate": "pnpm typecheck && pnpm typecheck:strict && pnpm type-coverage && pnpm test && pnpm lint && pnpm lint:oxlint && pnpm pack:check",
    "validate:compat": "pnpm typecheck && pnpm typecheck:strict && pnpm type-coverage && pnpm test:compat && pnpm lint && pnpm lint:oxlint && pnpm pack:check",
    "typecheck:strict": "tsc -p tsconfig.build.json --noEmit --strict --noImplicitAny --noUncheckedIndexedAccess",
    "type-coverage": "type-coverage --strict --at-least 99.5 -- src/index.ts src/constants.ts src/types.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "jiti": "^2.7.0",
    "oxlint": "^1.0.0",
    "release-it": "20.1.0",
    "type-coverage": "^2.29.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
    "hooks": {
      "before:init": "pnpm validate"
    },
    "git": {
      "requireBranch": "main",
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "commitArgs": [
        "--no-verify"
      ],
      "tagName": "v${version}",
      "tagAnnotation": "Release ${version}",
      "push": true,
      "pushArgs": [
        "--follow-tags"
      ]
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    }
  }
}
