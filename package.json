{
  "name": "eslint-plugin-legibility",
  "version": "0.1.0",
  "description": "ESLint and Oxlint JS plugin rules for readable, performance-conscious code.",
  "license": "MIT",
  "author": "Jeffry Wainwright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yowainwright/eslint-plugin-legibility.git"
  },
  "bugs": {
    "url": "https://github.com/yowainwright/eslint-plugin-legibility/issues"
  },
  "homepage": "https://github.com/yowainwright/eslint-plugin-legibility#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "oxlint",
    "readability",
    "legibility",
    "performance",
    "ai"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE.md",
    "README.md",
    "SECURITY.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm build:plugin && pnpm build:runtime",
    "build:plugin": "tsc -p tsconfig.build.json",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "typecheck": "pnpm build:plugin && tsc -p tsconfig.json",
    "lint": "pnpm build:plugin && eslint .",
    "lint:oxlint": "oxlint .",
    "pack:check": "pnpm build:plugin && pnpm pack --json --pack-destination ./.npm-cache",
    "prepack": "pnpm build:plugin",
    "release": "pnpm build:runtime && node .build/scripts/release.js",
    "release:patch": "pnpm build:runtime && node .build/scripts/release.js --increment=patch",
    "release:patch:dry": "pnpm build:runtime && node .build/scripts/release.js --increment=patch --dry-run",
    "release:minor": "pnpm build:runtime && node .build/scripts/release.js --increment=minor",
    "release:minor:dry": "pnpm build:runtime && node .build/scripts/release.js --increment=minor --dry-run",
    "release:major": "pnpm build:runtime && node .build/scripts/release.js --increment=major",
    "release:major:dry": "pnpm build:runtime && node .build/scripts/release.js --increment=major --dry-run",
    "release:beta": "pnpm build:runtime && node .build/scripts/release.js --preRelease=beta",
    "release:beta:dry": "pnpm build:runtime && node .build/scripts/release.js --preRelease=beta --dry-run",
    "release:alpha": "pnpm build:runtime && node .build/scripts/release.js --preRelease=alpha",
    "release:alpha:dry": "pnpm build:runtime && node .build/scripts/release.js --preRelease=alpha --dry-run",
    "release:tag": "pnpm build:runtime && node .build/scripts/tag-release.js",
    "release:tag:dry": "pnpm build:runtime && node .build/scripts/tag-release.js --dry-run",
    "release:tag:trusted": "pnpm build:runtime && node .build/scripts/tag-release.js --trusted-publishing",
    "release:dry": "pnpm build:runtime && node .build/scripts/release.js --dry-run",
    "test": "pnpm build && node --test .build/tests/*.test.js",
    "validate": "pnpm typecheck && pnpm test && pnpm lint && pnpm lint:oxlint && pnpm pack:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "jiti": "^2.7.0",
    "oxlint": "^1.0.0",
    "release-it": "20.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): ${version}",
      "commitArgs": [
        "--no-verify"
      ],
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    }
  }
}
